{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProcessedSentimentDataset",
  "type": "object",
  "required": [
    "id",
    "text_original",
    "text_clean",
    "text_variant",
    "sentiment_label",
    "slang_label",
    "source",
    "split"
  ],
  "properties": {
    "id": { "type": "string" },
    "text_original": { "type": "string" },
    "text_clean": { "type": "string" },
    "text_variant": {
      "type": "string",
      "enum": ["original", "slang_masked", "mixed"]
    },
    "sentiment_label": {
      "type": "string",
      "enum": ["negative", "neutral", "positive"]
    },
    "slang_label": {
      "type": "string",
      "enum": ["slang_heavy", "formal"]
    },
    "source": { "type": "string" },
    "split": {
      "type": "string",
      "enum": ["train", "val", "test"]
    }
  }
}
